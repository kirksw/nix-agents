{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "Codex MCP server list",
  "type": "array",
  "items": {
    "oneOf": [
      {
        "type": "object",
        "required": ["type", "url"],
        "properties": {
          "type": { "type": "string", "enum": ["remote"] },
          "url": { "type": "string" },
          "environment": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        },
        "additionalProperties": false
      },
      {
        "type": "object",
        "required": ["type", "command"],
        "properties": {
          "type": { "type": "string", "enum": ["local"] },
          "command": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "environment": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    ]
  }
}
