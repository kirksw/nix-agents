{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "Amp Code config (amp.json)",
  "type": "object",
  "required": ["systemPrompt", "mcpServers"],
  "properties": {
    "systemPrompt": { "type": "string" },
    "mcpServers": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["name", "command"],
            "properties": {
              "name": { "type": "string" },
              "command": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": ["name", "url"],
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string" }
            },
            "additionalProperties": false
          }
        ]
      }
    }
  },
  "additionalProperties": false
}
