{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "properties": {
    "permissions": {
      "type": "object",
      "properties": {
        "allow": { "type": "array", "items": { "type": "string" } },
        "deny": { "type": "array", "items": { "type": "string" } },
        "ask": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "hooks": {
      "type": "object",
      "description": "Native Claude Code hooks mapped from nix-agents hook events",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "matcher": { "type": "string" },
            "hooks": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "type": { "type": "string", "enum": ["command"] },
                  "command": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  },
  "additionalProperties": false
}
